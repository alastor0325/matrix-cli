#!/bin/sh

# Unit tests — always required
pytest tests/unit/ --tb=short -q
if [ $? -ne 0 ]; then
  echo "pre-commit: unit tests failed — commit blocked"
  exit 1
fi

# Integration tests — only when credentials are present
if [ -f "$HOME/.matrix-cli/config" ]; then
  pytest tests/integration/ --tb=short -q
  if [ $? -ne 0 ]; then
    echo "pre-commit: integration tests failed — commit blocked"
    exit 1
  fi
fi

# Auto-update README when matrix-notify changes
if git diff --cached --name-only | grep -q "^matrix-notify$"; then
  if command -v claude >/dev/null 2>&1; then
    echo "pre-commit: matrix-notify changed — asking Claude to update README if needed..."
    DIFF=$(git diff --cached -- matrix-notify)
    printf '%s' "$DIFF" | claude -p "You are reviewing a diff of the matrix-notify CLI script.
If any user-facing behaviour changed — CLI subcommands, flags, setup steps, install behaviour, error messages — update README.md accordingly.
Only edit README.md. Do not change any other file. If nothing user-facing changed, do nothing.
The diff is provided via stdin." --allowedTools "Edit,Read" 2>/dev/null
    if ! git diff --quiet -- README.md; then
      git add README.md
      echo "pre-commit: README.md updated and staged."
    fi
  fi
fi
